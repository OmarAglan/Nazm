; حلقة.مجمع — حلقة تعدّ من 10 إلى 0 ثم تخرج برمز الخروج 42
; ./nazm examples/حلقة.مجمع -o حلقة.o && ld حلقة.o -e البداية -o حلقة
; ./حلقة ; echo $?   ← يجب أن يُظهر 42

.نص
.عام البداية

البداية:
    احمل ر2، ١٠       ; عداد = 10

الحلقة:
    انقص ر2            ; عداد--
    قارن ر2، 0         ; هل العداد = 0؟
    اقفز_لاصفر الحلقة  ; إذا لا، كرر

    احمل ر0، ٦٠       ; exit syscall
    احمل ر7، ٤٢       ; رمز الخروج = 42
    نداء_نظام
