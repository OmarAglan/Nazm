; مرحبا.نظم — كتابة رسالة UTF-8 ثم الخروج بنجاح على لينكس
;
;   نظم --صيغة إلف64 --خرج مرحبا.o examples/مرحبا.نظم
;   ld -o مرحبا -e الرئيسية مرحبا.o
;   ./مرحبا
;
; يستخدم نداءي النظام write (رقم ١) وexit (رقم ٦٠).

.نص
.عام الرئيسية

الرئيسية:
    ; write(1, رسالة, ٢٩): عدد بايتات UTF-8 من دون بايت الإنهاء الصفري
    انقل سجل_المركم، ١          ; رقم نداء النظام: write
    انقل فهرس_الوجهة، ١          ; واصف الملف: stdout
    انقل فهرس_المصدر، رسالة      ; عنوان النص
    انقل سجل_البيانات، ٢٩         ; طول النص بالبايت
    ناد_النظام

    ; exit(0)
    انقل سجل_المركم، ٦٠         ; رقم نداء النظام: exit
    خالف_بتيا فهرس_الوجهة، فهرس_الوجهة ; رمز الخروج = ٠
    ناد_النظام

.بيانات
رسالة: .سلسلة_منتهية_بصفر "مرحباً بالعالم!\n"
