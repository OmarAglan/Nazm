; مرحبا.مجمع — مرحباً بالعالم
; أول برنامج بلغة التجميع العربية نَظْم
;
; للتجميع والتشغيل على لينكس:
;   ./nazm examples/مرحبا.مجمع -o مرحبا.o -f elf64
;   ld مرحبا.o -e الرئيسية -o مرحبا
;   ./مرحبا
;
; يستخدم نداء النظام write (رقم ١) ثم exit (رقم ٦٠)

.نص
.عام الرئيسية

الرئيسية:
    ; write(1, رسالة, ٢٩)
    احمل ر0، ١          ; رقم نداء النظام: write
    احمل ر7، ١          ; المُعرَّف: stdout
    احمل ر6، رسالة      ; مؤشر النص
    احمل ر2، ٢٩         ; طول النص بالبايت
    نداء_نظام

    ; exit(0)
    احمل ر0، ٦٠         ; رقم نداء النظام: exit
    خالف ر7، ر7         ; رمز الخروج
    نداء_نظام

.بيانات
رسالة: .سلسلة "مرحباً بالعالم!\n"
